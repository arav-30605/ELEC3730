void MyOnScreenUpdate (void){
	// Calculate % grind remaining
	GrindTimeCountDownFloat=GrindTimeCountDown;
	GrindTimeFloat=GrindTime;
	percent = (GrindTimeCountDownFloat/GrindTimeFloat)*100;
	percentInt=round(percent);

	widthfill=(5.99)*percentInt; //(599-0)

	// Choose colour: 100–51% green, 50–21% yellow, 20–0% red
	uint32_t barColour;
	if (percentInt > 50) {
		barColour = UTIL_LCD_COLOR_GREEN;          // early in grind
	} else if (percentInt > 20) {
		barColour = UTIL_LCD_COLOR_YELLOW;         // middle
