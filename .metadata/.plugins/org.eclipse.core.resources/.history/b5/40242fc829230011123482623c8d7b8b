void StartTaskdisplay(void *argument)
{
	// Start with OFF screen
	MyOffScreen();

	// Queue Setup
	// Recieve Display Queue
	uint16_t ScreenStateChange;
	osStatus_t ScreenStatus;

	for(;;)
	{
		ScreenStatus = osMessageQueueGet(ScreenQueueHandle, &ScreenStateChange, NULL, osWaitForever);
		if (ScreenStatus==osOK){
			if ((ScreenStateChange==1)&&(current_state==STATE_OFF)) {
				MyOffScreenUpdate();
			}
			if ((ScreenStateChange==1)&&(current_state==STATE_ON)) {
				MyOnScreenUpdate();
			}
			if ((ScreenStateChange==3)&&(current_state==STATE_OFF)){
				MyOffScreen();
				MyOffScreenUpdate();
			}
			if ((ScreenStateChange==4)&&(current_state==STATE_PAUSED)){
				//Fill with blue if in paused state
				MyPauseScreenUpdate();
			}
		}
		osDelay(1);
	}
}

