void MyOnScreenUpdate (void){
	// CLEAR PAUSE TIMER AREA (when resuming)
	    UTIL_LCD_FillRect(0,140,800,120,UTIL_LCD_COLOR_BLACK);
	// Calculate % grind remaining
	GrindTimeCountDownFloat=GrindTimeCountDown;
	GrindTimeFloat=GrindTime;
	percent = (GrindTimeCountDownFloat/GrindTimeFloat)*100;
	percentInt=round(percent);

	widthfill=(5.99)*percentInt; //(599-0)

	// Choose colour: 100–51% green, 50–21% yellow, 20–0% red
	uint8_t r, g, b;
	float p = percent;   // use float for smoothness

	if (p > 100.0f) p = 100.0f;
	if (p < 0.0f)   p = 0.0f;

	// Smooth gradient
	// Each RGB channel has 0-255 (FF) values, so I can play with it to get a transition.
	if (p > 50.0f) {
	    // Green to Yellow
		// In this part green stays the same, but red needs to change from 0 to 255.
	    r = (uint8_t)(255.0f * (100.0f - p) / 50.0f);  // 0 → 255
	    g = 255;
	} else {
	    // Yellow to Red
		// In this part red stays the same, but green needs to change from 0 to 255.
	    r = 255;
	    g = (uint8_t)(255.0f * p / 50.0f);             // 255 → 0
	}

	b = 0;

	// inserting the function back to the 32 bit value.
	// from green to yellow to red, the blue is unaffected so it stays 0.
	// same remains for the alpha channel as well.
	uint32_t barColour = (0xFF << 24) | (r << 16) | (g << 8) | b;

	UTIL_LCD_SetFont(&Font16);
	UTIL_LCD_DisplayStringAt(0,280,(uint32_t*)"Remaining   Time",CENTER_MODE);


	//Progress bar inside
	if (current_state==STATE_ON){
		UTIL_LCD_FillRect(101,411,599,59,UTIL_LCD_COLOR_BLACK); //clear box
		UTIL_LCD_FillRect(101,411,widthfill,59,barColour); //Fill with green
		UTIL_LCD_SetFont(&Font24);
		UTIL_LCD_DisplayStringAt(0,90,(uint32_t*)"PAUSE",CENTER_MODE);
	}

	// Bottom box
	UTIL_LCD_DrawRect(100,410,600,60,UTIL_LCD_COLOR_WHITE);

	// Text in output box
	UTIL_LCD_SetFont(&Font24);

	UTIL_LCD_DrawRect(100,410,600,60,UTIL_LCD_COLOR_WHITE);
	switch((int)GrindTimeCountDown){
	case 0:
		UTIL_LCD_DisplayStringAt(0,320,(uint32_t*) " 0 " ,CENTER_MODE);
		break;
	case 1:
		UTIL_LCD_DisplayStringAt(0,320,(uint32_t*) " 1 " ,CENTER_MODE);
		break;
	case 2:
		UTIL_LCD_DisplayStringAt(0,320,(uint32_t*) " 2 " ,CENTER_MODE);
		break;
	case 3:
